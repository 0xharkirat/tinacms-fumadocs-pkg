{
  "name": "tinacms-fumadocs-pkg",
  "version": "0.0.0",
  "description": "Add TinaCMS visual/contextual editing to a Fumadocs (Next.js App Router) site without reimplementing Fumadocs' renderer.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./bridge": "./src/bridge.tsx",
    "./live-body": "./src/live-body.tsx",
    "./live-toc": "./src/live-toc.tsx",
    "./client-compile": "./src/client-compile.ts",
    "./strip-mdx": "./src/strip-mdx.ts",
    "./markers": "./src/markers.tsx",
    "./templates": "./src/templates.ts",
    "./components": "./src/components.ts"
  },
  "files": [
    "src",
    "bin",
    "templates"
  ],
  "bin": {
    "tinacms-fumadocs-pkg": "./bin/cli.mjs"
  },
  "peerDependencies": {
    "@fumadocs/mdx-remote": ">=1",
    "@mdx-js/mdx": ">=3",
    "@tinacms/bridge": "^0.3.0",
    "@tinacms/mdx": ">=2",
    "fumadocs-core": ">=15",
    "fumadocs-ui": ">=15",
    "next": ">=15",
    "react": ">=18",
    "tinacms": ">=3"
  },
  "keywords": [
    "tinacms",
    "fumadocs",
    "visual-editing",
    "mdx",
    "nextjs"
  ],
  "license": "MIT",
  "devDependencies": {
    "@tinacms/bridge": "^0.3.0",
    "@types/mdx": "^2.0.14",
    "@types/react": "^19.2.17",
    "next": "^16.2.9",
    "react": "^19.2.7"
  }
}
